---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/organisms/Navbar.astro'
import Footer from '../components/organisms/Footer.astro'
import PageHero from '../components/organisms/PageHero.astro'
import CategoryFiltersSection from '../components/organisms/CategoryFiltersSection.astro'
import ExperiencesGrid from '../components/organisms/ExperiencesGrid.astro'
import MethodologyTeaserSection from '../components/organisms/MethodologyTeaserSection.astro'
import data from '../data/experiencias.json'
---

<BaseLayout title="Experiencias" description="Nuestra selección editorial de momentos que definen el carácter de Nicaragua.">
  <Navbar />
  <main class="max-w-container-max mx-auto px-margin-mobile md:px-gutter py-stack-md">
    <PageHero
      title="Explorar Experiencias"
      description="Nuestra selección editorial de momentos que definen el carácter de Nicaragua. Desde el amanecer en un cafetal hasta la serenidad de los manglares."
      label="DESCUBRIMIENTO CURADO"
    />
    <CategoryFiltersSection />
    <ExperiencesGrid experiencias={data} />
  </main>
  <MethodologyTeaserSection />
  <Footer />
</BaseLayout>
