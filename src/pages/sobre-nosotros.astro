---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/organisms/Navbar.astro'
import Footer from '../components/organisms/Footer.astro'
import PageHero from '../components/organisms/PageHero.astro'
import MissionSection from '../components/organisms/MissionSection.astro'
import MethodCardsSection from '../components/organisms/MethodCardsSection.astro'
import ValuesMosaicSection from '../components/organisms/ValuesMosaicSection.astro'
import MethodologyCTASection from '../components/organisms/MethodologyCTASection.astro'
---

<BaseLayout
  title="Sobre Nosotros"
  description="Sabores & Experiencias nace de la necesidad de recuperar la veracidad en la era digital. Conocé nuestra historia y metodología."
>
  <Navbar />
  <main>
    <PageHero
      title="La mirada que descubre lo auténtico."
      label="Nuestra Misión"
      description=""
      image="https://images.unsplash.com/photo-1605540436563-5bca919ae7e9?w=1600&q=80"
    />
    <MissionSection />
    <MethodCardsSection />
    <ValuesMosaicSection />
    <MethodologyCTASection />
  </main>
  <Footer />
</BaseLayout>
