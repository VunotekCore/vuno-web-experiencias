---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/organisms/Navbar.astro'
import Footer from '../components/organisms/Footer.astro'
import HeroSection from '../components/organisms/HeroSection.astro'
import IntroFeatureSection from '../components/organisms/IntroFeatureSection.astro'
import CategoriesSection from '../components/organisms/CategoriesSection.astro'
import ChroniclesSection from '../components/organisms/ChroniclesSection.astro'
import BentoQuoteSection from '../components/organisms/BentoQuoteSection.astro'
import MethodSection from '../components/organisms/MethodSection.astro'
import { site } from '../config/site'
import data from '../data/experiencias.json'
---

<BaseLayout title="Inicio" description={site.seo.defaultDescription}>
  <Navbar />
  <main>
    <HeroSection />
    <IntroFeatureSection />
    <CategoriesSection />
    <ChroniclesSection experiencias={data} />
    <BentoQuoteSection />
    <MethodSection />
  </main>
  <Footer />
</BaseLayout>
