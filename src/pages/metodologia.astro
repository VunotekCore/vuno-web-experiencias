---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/organisms/Navbar.astro'
import Footer from '../components/organisms/Footer.astro'
import PageHero from '../components/organisms/PageHero.astro'
import MethodCardsSection from '../components/organisms/MethodCardsSection.astro'
import ValuesMosaicSection from '../components/organisms/ValuesMosaicSection.astro'
import MethodologyCTASection from '../components/organisms/MethodologyCTASection.astro'
---

<BaseLayout
  title="Metodología"
  description="Conocé nuestra metodología editorial: visitas anónimas, observación estructurada y transparencia radical."
>
  <Navbar />
  <main>
    <PageHero
      title="Nuestra Metodología"
      label="Nuestro Método"
      description="No otorgamos estrellas. No construimos rankings. Describimos lo que encontramos."
      image="https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=1600&q=80"
    />
    <MethodCardsSection />
    <ValuesMosaicSection />
    <MethodologyCTASection />
  </main>
  <Footer />
</BaseLayout>
