---
import Button from '../atoms/Button.astro'
import AnimatedReveal from '../atoms/AnimatedReveal.astro'
import CardExperiencia from '../molecules/CardExperiencia.astro'
import type { Experiencia } from '../../data/experiencias'

interface Props {
  experiencias: Experiencia[]
}
---

<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-stack-md mt-stack-md">
  {Astro.props.experiencias.map((exp, i) => (
    <AnimatedReveal delay={(i % 3 + 1) as 1 | 2 | 3}>
      <CardExperiencia {...exp} />
    </AnimatedReveal>
  ))}
</section>

<div class="flex justify-center mt-stack-lg">
  <Button variant="ghost">Ver más experiencias</Button>
</div>
