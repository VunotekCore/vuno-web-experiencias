---
import LabelTag from '../atoms/LabelTag.astro'
import Button from '../atoms/Button.astro'
---

<section class="relative h-[85vh] w-full overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-primary/40 z-10"></div>
    <img
      class="w-full h-full object-cover"
      src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=1600&q=80"
      alt="Vista editorial de León, Nicaragua al atardecer"
      loading="eager"
    />
  </div>
  <div class="relative z-20 h-full max-w-container-max mx-auto px-margin-mobile md:px-gutter flex flex-col justify-center items-start text-white">
    <LabelTag color="white">Crónicas de lugares y momentos</LabelTag>
    <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg max-w-3xl mb-6 mt-4">Nicaragua se vive mejor cuando se recorre con atención.</h1>
    <p class="font-body-lg text-body-lg max-w-xl mb-10 opacity-90">
      No otorgamos estrellas. No construimos rankings. <br/>Describimos lo que encontramos.
    </p>
    <div class="flex flex-wrap gap-4">
      <Button variant="primary">Explorar Crónicas</Button>
      <Button variant="ghost-white">Conocer la Metodología</Button>
    </div>
  </div>
</section>
