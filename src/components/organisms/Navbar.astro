---
import { site } from '../../config/site'
import { Search, Menu, X } from 'lucide'
import { icon } from '../../lib/lucide'
import { getLangFromUrl, getEnPath, getEsPath, t } from '../../i18n'

const lang = getLangFromUrl(Astro.url)
const currentPath = Astro.url.pathname
const otherLangPath = lang === 'es' ? getEnPath(currentPath) : getEsPath(currentPath)

const flagSvg = lang === 'es'
  ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 600" width="18" height="12" style="border-radius:1px;vertical-align:middle"><rect width="900" height="600" fill="#C60A1E"/><rect y="200" width="900" height="200" fill="#FFC400"/></svg>'
  : '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 7410 3900" width="18" height="12" style="border-radius:1px;vertical-align:middle"><rect width="7410" height="3900" fill="#B22234"/><rect y="600" width="7410" height="300" fill="#fff"/><rect y="1200" width="7410" height="300" fill="#B22234"/><rect y="1800" width="7410" height="300" fill="#fff"/><rect y="2400" width="7410" height="300" fill="#B22234"/><rect y="3000" width="7410" height="300" fill="#fff"/><rect y="3600" width="7410" height="300" fill="#B22234"/><rect width="2964" height="2100" fill="#3C3B6E"/></svg>'

const navItems = [
  { key: 'nav.inicio', href: lang === 'en' ? '/en' : '/' },
  { key: 'nav.experiencias', href: lang === 'en' ? '/en/experiencias' : '/experiencias' },
  { key: 'nav.sobre-nosotros', href: lang === 'en' ? '/en/sobre-nosotros' : '/sobre-nosotros' },
  { key: 'nav.metodologia', href: lang === 'en' ? '/en/metodologia' : '/metodologia' },
]
---

<header class="bg-surface sticky top-0 z-50 border-b border-primary/10">
  <nav class="flex justify-between items-center w-full px-margin-mobile md:px-gutter max-w-container-max mx-auto h-20">
    <a href="/" class="text-headline-md font-display-lg text-primary flex items-center gap-2 no-underline">
      <span class="serif font-bold tracking-tight">{site.brand.name}</span>
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
          return (
            <li>
              <a
                href={item.href}
                class={`font-label-caps text-label-caps transition-all ${
                  isActive
                    ? 'text-primary border-b-2 border-secondary pb-1'
                    : 'text-on-surface-variant hover:text-secondary'
                }`}
              >
                {t(lang, item.key)}
              </a>
            </li>
          )
        })
      }
    </ul>

    <div class="flex items-center gap-4">
      <a
        href={otherLangPath}
        class="text-on-surface-variant hover:text-secondary transition-colors font-label-caps text-[11px] tracking-wider flex items-center gap-1.5"
        aria-label={t(lang, 'navbar.idioma')}
      >
        <span set:html={flagSvg} />
        <span>{t(lang, 'navbar.idioma')}</span>
      </a>
      <button class="text-primary hover:text-secondary transition-colors" aria-label={t(lang, 'navbar.buscar')}>
        <span set:html={icon(Search, 22, 1.5)} />
      </button>
      <button id="mobileMenuBtn" class="md:hidden text-primary" aria-label={t(lang, 'navbar.buscar')}>
        <span set:html={icon(Menu, 24, 1.5)} />
      </button>
    </div>
  </nav>
</header>

<!-- Mobile menu overlay -->
<div id="mobileMenu" class="fixed inset-0 z-50 md:hidden hidden">
  <div id="mobileMenuBackdrop" class="absolute inset-0 bg-primary/40 backdrop-blur-sm"></div>
  <div class="absolute top-0 right-0 h-full w-80 max-w-[85vw] bg-surface shadow-xl flex flex-col">
    <div class="flex items-center justify-between px-5 py-5 border-b border-primary/10">
      <span class="font-label-caps text-label-caps text-secondary tracking-widest">{t(lang, 'footer.navegacion')}</span>
      <button id="mobileMenuClose" class="text-secondary hover:text-primary transition-colors" aria-label="Cerrar">
        <span set:html={icon(X, 20, 1.5)} />
      </button>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-6">
      <div class="flex flex-col gap-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="block py-3 px-3 -mx-3 font-body-md text-body-md text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-colors rounded-sm"
            >
              {t(lang, item.key)}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobileMenuBtn')
  const menuClose = document.getElementById('mobileMenuClose')
  const menu = document.getElementById('mobileMenu')
  const backdrop = document.getElementById('mobileMenuBackdrop')

  function open() { menu?.classList.remove('hidden') }
  function close() { menu?.classList.add('hidden') }

  menuBtn?.addEventListener('click', open)
  menuClose?.addEventListener('click', close)
  backdrop?.addEventListener('click', close)

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close()
  })
</script>
