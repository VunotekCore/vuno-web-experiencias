---
interface Props {
  variant?: 'light' | 'dark'
  placeholder?: string
}

const { variant = 'light', placeholder = 'Correo electrónico' } = Astro.props
const isDark = variant === 'dark'
---

<form class="flex border-b pb-2 {isDark ? 'border-on-primary/30' : 'border-primary/20'}">
  <input
    type="email"
    placeholder={placeholder}
    class="bg-transparent border-none focus:ring-0 w-full font-body-md text-sm {isDark ? 'text-on-primary placeholder:text-on-primary/40' : 'text-primary placeholder:text-on-surface-variant/40'}"
  />
  <button type="submit" class="flex-shrink-0">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={isDark ? 'text-secondary-container' : 'text-secondary'}>
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </svg>
  </button>
</form>
