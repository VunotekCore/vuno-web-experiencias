---
import { icon } from '../../lib/lucide'
import type { IconNode } from '../../lib/lucide'

interface Props {
  label: string
  icon: IconNode
  active?: boolean
}
---

<button class="flex flex-col items-center gap-3 p-6 border border-primary/10 hover:border-secondary transition-all group">
  <span class="text-primary-container group-hover:scale-110 transition-transform" set:html={icon(Astro.props.icon, 24, 1.5)} />
  <span class="font-label-caps text-label-caps">{Astro.props.label}</span>
</button>
