---
import '../styles/global.css'
import { site } from '../config/site'
import SEOMeta from '../components/seo/SEOMeta.astro'
import { getLangFromUrl, type Lang } from '../i18n'

interface SEOData {
  ogImage?: string
  ogType?: 'website' | 'article'
  noindex?: boolean
  canonical?: string
}

interface Props {
  title: string
  description?: string
  seo?: SEOData
  lang?: Lang
}

const { title, description = site.seo.defaultDescription, seo = {} } = Astro.props
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url)
---

<!doctype html>
<html lang={lang} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {site.brand.name}</title>
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SEOMeta
      title={`${title} | ${site.brand.name}`}
      description={description}
      ogImage={seo.ogImage || site.seo.ogDefaultImage}
      ogType={seo.ogType}
      noindex={seo.noindex}
      canonical={seo.canonical}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&family=Work+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="overflow-x-hidden">
    <slot />
  </body>
</html>
